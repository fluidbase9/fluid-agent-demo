# ─────────────────────────────────────────────────────────────────────
#  fluid-agent-demo — environment variables
#  Copy this file to .env and fill in your keys
#  Get keys: npx @fluidwallet/fadp-cli
# ─────────────────────────────────────────────────────────────────────

# Fluid Agent Key — powers crypto operations (send, balance, swap)
# Get from: Developer Dashboard → API Keys tab → Generate Key
FLUID_AGENT_KEY=fwag_your_key_here

# FLDP EC Key — identifies your server to the Fluid backend (FADP gating)
# Get from: npx @fluidwallet/fadp-cli
FLDP_API_KEY_NAME=fluid/devkeys/your_org/your_key_id
FLDP_API_KEY_PRIVATE_KEY={"name":"...","privateKey":"-----BEGIN PRIVATE KEY-----\n..."}

# Fluid Ticker API key (optional — 100 free calls/month without one)
FLUID_TICKER_KEY=

# Server port
PORT=3001

# Fluid API base URL (leave as default)
FLUID_API_URL=https://fluidnative.com
